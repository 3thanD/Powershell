function Get-SwitchInfo {
	$Packet = Invoke-DiscoveryProtocolCapture -Type LLDP
	Get-DiscoveryProtocolData -Packet $Packet
}
 
function Get-IPaddress { 
	(Invoke-WebRequest -uri "https://api.ipify.org/").Content
}
